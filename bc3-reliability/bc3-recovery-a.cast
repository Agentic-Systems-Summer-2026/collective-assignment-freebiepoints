[0.016023, "o", "=== Demo A: Checkpoint + Rollback Recovery ===\r\n\r\n--- Step 1: Clean slate ---\r\nRemoved checkpoint and report.\r\n\r\n--- Step 2: Start fixed_agent.py, kill it after 2 items complete ---\r\n"]
